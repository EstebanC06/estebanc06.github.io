---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const translations = {
	back: { en: '← Back to Evidences', es: '← Volver a Evidencias' },
	stack: { en: 'Technologies', es: 'Tecnologías' },
	links: { en: 'Links', es: 'Enlaces' },
	gallery: { en: 'Gallery', es: 'Galería' },
	repo: { en: 'Repo', es: 'Repo' },
};

// ─── EDITA ESTA SECCIÓN CON TU PROYECTO ─────────────────────────────────────
const project = {
	titleES: 'Proyecto Final — Bases de Datos',
	titleEN: 'Final Project — Databases',
	summaryES: 'Descripción breve de tu proyecto de bases de datos. Edita este texto cuando tengas tu proyecto definido.',
	summaryEN: 'Brief description of your database project. Edit this text when your project is defined.',
	stack: ['Oracle Database 19c', 'PL/SQL', 'SQL Developer'],
	repoURL: '', // Pon la URL de tu repositorio cuando lo tengas, ej: 'https://github.com/EstebanC06/proyecto-bd'
	// Imágenes: pon las rutas relativas a /public, ej: '/proyecto-bd/diagrama.png'
	// Sube tus imágenes a public/proyecto-bd/ y agrégalas aquí
	images: [] as string[],
};
// ─────────────────────────────────────────────────────────────────────────────
---

<Layout title={`Proyecto BD | David Caicedo`}>
	<Header />

	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<article class="max-w-3xl mx-auto pt-24 sm:pt-32 md:pt-48 pb-16 sm:pb-24 fade-in">

			<a href="/projects"
				class="text-sm font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors mb-8 inline-block"
				data-en={translations.back.en} data-es={translations.back.es}>
				{translations.back.en}
			</a>

			<header class="mb-12">
				<h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-6">
					<span class="locale-es">{project.titleES}</span>
					<span class="locale-en">{project.titleEN}</span>
				</h1>
				<p class="text-lg text-gray-600 dark:text-gray-400">
					<span class="locale-es">{project.summaryES}</span>
					<span class="locale-en">{project.summaryEN}</span>
				</p>
			</header>

			<div class="space-y-12">

				{/* Stack */}
				<section>
					<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4"
						data-en={translations.stack.en} data-es={translations.stack.es}>
						{translations.stack.en}
					</h2>
					<div class="flex flex-wrap gap-2">
						{project.stack.map((tech) => (
							<span class="px-3 py-1 text-sm font-medium rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-transparent hover:border-gray-300 dark:hover:border-gray-600 transition-all duration-300 cursor-default">
								{tech}
							</span>
						))}
					</div>
				</section>

				{/* Repo */}
				{project.repoURL && (
					<section>
						<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4"
							data-en={translations.links.en} data-es={translations.links.es}>
							{translations.links.en}
						</h2>
						<div class="flex flex-wrap gap-4">
							<a href={project.repoURL} target="_blank" rel="noopener noreferrer"
								class="text-sm font-medium text-gray-900 dark:text-white hover:text-primary transition-colors flex items-center gap-1"
								data-en={translations.repo.en} data-es={translations.repo.es}>
								{translations.repo.en}
								<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
								</svg>
							</a>
						</div>
					</section>
				)}

				{/* Galería */}
				{project.images.length > 0 ? (
					<section>
						<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-6"
							data-en={translations.gallery.en} data-es={translations.gallery.es}>
							{translations.gallery.en}
						</h2>
						<div class="grid grid-cols-1 gap-8">
							{project.images.map((src) => (
								<div class="relative rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50">
									<img src={src} alt="Project screenshot" class="w-full h-auto" loading="lazy" />
								</div>
							))}
						</div>
					</section>
				) : (
					<section>
						<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-6"
							data-en={translations.gallery.en} data-es={translations.gallery.es}>
							{translations.gallery.en}
						</h2>
						<div class="flex flex-col items-center justify-center py-16 text-center border border-dashed border-gray-300 dark:border-gray-700 rounded-2xl">
							<span class="text-4xl mb-4">🖼️</span>
							<p class="text-gray-500 dark:text-gray-400 text-sm"
								data-en="Gallery will be added when the project is complete."
								data-es="La galería se agregará cuando el proyecto esté completo.">
								La galería se agregará cuando el proyecto esté completo.
							</p>
						</div>
					</section>
				)}

			</div>
		</article>
	</main>

	<Footer />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			document.querySelector('.fade-in')?.classList.add('visible');
		});
	</script>
</Layout>

<style>
	@reference "../../styles/global.css";
</style>
