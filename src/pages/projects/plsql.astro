		file: '/scripts/plsql/09-taller-nomina-avanzado.sql',
		description: 'Sistema completo de nómina: bloque anónimo, funciones encadenadas, procedimiento con excepciones, package PKG_NOMINA con sobrecarga, función pipelined, BULK COLLECT/FORALL y compound trigger.',
		descriptionEN: 'Full payroll system: anonymous block, chained functions, procedure with exceptions, PKG_NOMINA package with overloading, pipelined function, BULK COLLECT/FORALL and compound trigger.',
		code: `-- =====================================================================
-- TALLER AVANZADO PL/SQL — SISTEMA DE LIQUIDACIÓN DE NÓMINA
-- Universidad El Bosque — Bases de Datos 2
-- Autores: David Caicedo / Nicolas Zambrano
-- =====================================================================

SET SERVEROUTPUT ON SIZE UNLIMITED;

-- ============================================================
-- PUNTO 1 — Bloque anónimo: Liquidación individual
-- ============================================================
DECLARE
    v_id_empleado   EMPLEADOS.id_empleado%TYPE  := 1006;
    v_nombre        EMPLEADOS.nombre%TYPE;
    v_tipo_contrato EMPLEADOS.tipo_contrato%TYPE;
    v_salario_base  EMPLEADOS.salario_base%TYPE;
    v_fecha_ingreso EMPLEADOS.fecha_ingreso%TYPE;
    v_cod_sede      EMPLEADOS.cod_sede%TYPE;
    v_estado        EMPLEADOS.estado%TYPE;

    v_id_quincena   VARCHAR2(15) := '2026-Q1-ENE';
    v_salario_base_q NUMBER(12,2) := 0;
    v_recargos       NUMBER(12,2) := 0;
    v_bonificacion   NUMBER(12,2) := 0;
    v_subtotal       NUMBER(12,2) := 0;
    v_antiguedad     NUMBER(5)    := 0;
    v_valor_hora     NUMBER(12,4) := 0;
    v_num_sanciones  NUMBER(5)    := 0;

    v_ret_servicios  NUMBER(5,2);
    v_rec_nocturno   NUMBER(5,2);
    v_rec_dominical  NUMBER(5,2);
    v_rec_noct_dom   NUMBER(5,2);
    v_nombre_sede    SEDES.nombre_sede%TYPE;

    CURSOR cur_horas(p_id_empleado NUMBER, p_id_quincena VARCHAR2) IS
        SELECT tipo_hora, cantidad_horas
        FROM   HORAS_TRABAJADAS
        WHERE  id_empleado = p_id_empleado
        AND    id_quincena = p_id_quincena;
    r_hora cur_horas%ROWTYPE;
BEGIN
    SELECT id_empleado, nombre, tipo_contrato, salario_base,
           fecha_ingreso, cod_sede, estado
    INTO   v_id_empleado, v_nombre, v_tipo_contrato, v_salario_base,
           v_fecha_ingreso, v_cod_sede, v_estado
    FROM   EMPLEADOS WHERE id_empleado = v_id_empleado;

    SELECT nombre_sede INTO v_nombre_sede FROM SEDES WHERE cod_sede = v_cod_sede;
    SELECT valor_numerico INTO v_ret_servicios FROM PARAMETROS WHERE cod_parametro = 'RET_SERVICIOS';
    SELECT valor_numerico INTO v_rec_nocturno  FROM PARAMETROS WHERE cod_parametro = 'RECARGO_NOCTURNO';
    SELECT valor_numerico INTO v_rec_dominical FROM PARAMETROS WHERE cod_parametro = 'RECARGO_DOMINICAL';
    SELECT valor_numerico INTO v_rec_noct_dom  FROM PARAMETROS WHERE cod_parametro = 'RECARGO_NOCT_DOM';

    v_antiguedad := TRUNC(MONTHS_BETWEEN(SYSDATE, v_fecha_ingreso) / 12);

    IF v_tipo_contrato = 'PLANTA' THEN
        v_salario_base_q := v_salario_base / 2;
        v_valor_hora     := v_salario_base / 240;
    ELSIF v_tipo_contrato = 'TEMPORAL' THEN
        SELECT NVL(SUM(CASE WHEN tipo_hora = 'NORMAL' THEN cantidad_horas ELSE 0 END), 0)
        INTO   v_salario_base_q
        FROM   HORAS_TRABAJADAS
        WHERE  id_empleado = v_id_empleado AND id_quincena = v_id_quincena;
        v_salario_base_q := v_salario_base * v_salario_base_q;
        v_valor_hora     := v_salario_base;
    ELSIF v_tipo_contrato = 'SERVICIOS' THEN
        v_salario_base_q := (v_salario_base - (v_salario_base * v_ret_servicios / 100)) / 2;
        v_valor_hora     := 0;
    END IF;

    IF v_tipo_contrato != 'SERVICIOS' THEN
        OPEN cur_horas(v_id_empleado, v_id_quincena);
        LOOP
            FETCH cur_horas INTO r_hora;
            EXIT WHEN cur_horas%NOTFOUND;
            IF    r_hora.tipo_hora = 'NOCTURNA'     THEN v_recargos := v_recargos + r_hora.cantidad_horas * v_valor_hora * v_rec_nocturno  / 100;
            ELSIF r_hora.tipo_hora = 'DOMINICAL'    THEN v_recargos := v_recargos + r_hora.cantidad_horas * v_valor_hora * v_rec_dominical / 100;
            ELSIF r_hora.tipo_hora = 'NOCTURNA_DOM' THEN v_recargos := v_recargos + r_hora.cantidad_horas * v_valor_hora * v_rec_noct_dom  / 100;
            END IF;
        END LOOP;
        CLOSE cur_horas;

        SELECT COUNT(*) INTO v_num_sanciones FROM SANCIONES
        WHERE  id_empleado = v_id_empleado
        AND    fecha_sancion >= ADD_MONTHS(SYSDATE, -6);

        IF v_num_sanciones > 2 THEN
            v_bonificacion := 0;
        ELSE
            v_bonificacion := CASE
                WHEN v_antiguedad BETWEEN 3 AND 5  THEN v_salario_base_q * 0.03
                WHEN v_antiguedad BETWEEN 6 AND 10 THEN v_salario_base_q * 0.06
                WHEN v_antiguedad > 10             THEN v_salario_base_q * 0.10
                ELSE 0
            END;
        END IF;
    END IF;

    v_subtotal := v_salario_base_q + v_recargos + v_bonificacion;
    DBMS_OUTPUT.PUT_LINE('=== LIQUIDACIÓN QUINCENAL ===');
    DBMS_OUTPUT.PUT_LINE('Empleado:      ' || v_nombre || ' (' || v_id_empleado || ')');
    DBMS_OUTPUT.PUT_LINE('Salario base Q: ' || TO_CHAR(v_salario_base_q, 'FM9,999,999.00'));
    DBMS_OUTPUT.PUT_LINE('Recargos:       ' || TO_CHAR(v_recargos,       'FM9,999,999.00'));
    DBMS_OUTPUT.PUT_LINE('Bonificación:   ' || TO_CHAR(v_bonificacion,   'FM9,999,999.00'));
    DBMS_OUTPUT.PUT_LINE('SUBTOTAL:       ' || TO_CHAR(v_subtotal,       'FM9,999,999.00'));
EXCEPTION
    WHEN NO_DATA_FOUND THEN DBMS_OUTPUT.PUT_LINE('ERROR: Empleado no encontrado.');
    WHEN OTHERS        THEN DBMS_OUTPUT.PUT_LINE('ERROR: ' || SQLERRM);
END;
/

-- ============================================================
-- PUNTO 2 — Funciones standalone encadenadas
-- ============================================================

-- 2.1 fn_salario_base_q
CREATE OR REPLACE FUNCTION fn_salario_base_q(p_id_empleado NUMBER, p_id_quincena VARCHAR2)
RETURN NUMBER IS
    v_tipo  EMPLEADOS.tipo_contrato%TYPE;
    v_sal   EMPLEADOS.salario_base%TYPE;
    v_horas NUMBER := 0;
    v_ret   NUMBER;
BEGIN
    SELECT tipo_contrato, salario_base INTO v_tipo, v_sal
    FROM   EMPLEADOS WHERE id_empleado = p_id_empleado;

    IF v_tipo = 'PLANTA' THEN RETURN v_sal / 2;
    ELSIF v_tipo = 'TEMPORAL' THEN
        BEGIN
            SELECT NVL(cantidad_horas, 0) INTO v_horas FROM HORAS_TRABAJADAS
            WHERE  id_empleado = p_id_empleado AND id_quincena = p_id_quincena AND tipo_hora = 'NORMAL';
        EXCEPTION WHEN NO_DATA_FOUND THEN v_horas := 0;
        END;
        RETURN v_sal * v_horas;
    ELSIF v_tipo = 'SERVICIOS' THEN
        SELECT valor_numerico INTO v_ret FROM PARAMETROS WHERE cod_parametro = 'RET_SERVICIOS';
        RETURN (v_sal - (v_sal * v_ret / 100)) / 2;
    END IF;
    RETURN 0;
END fn_salario_base_q;
/

-- 2.2 fn_recargos
CREATE OR REPLACE FUNCTION fn_recargos(p_id_empleado NUMBER, p_id_quincena VARCHAR2)
RETURN NUMBER IS
    v_tipo  EMPLEADOS.tipo_contrato%TYPE;
    v_sal   EMPLEADOS.salario_base%TYPE;
    v_vh    NUMBER;
    v_total NUMBER := 0;
    v_rn NUMBER; v_rd NUMBER; v_rnd NUMBER;
BEGIN
    SELECT tipo_contrato, salario_base INTO v_tipo, v_sal FROM EMPLEADOS WHERE id_empleado = p_id_empleado;
    IF v_tipo = 'SERVICIOS' THEN RETURN 0; END IF;
    SELECT valor_numerico INTO v_rn  FROM PARAMETROS WHERE cod_parametro = 'RECARGO_NOCTURNO';
    SELECT valor_numerico INTO v_rd  FROM PARAMETROS WHERE cod_parametro = 'RECARGO_DOMINICAL';
    SELECT valor_numerico INTO v_rnd FROM PARAMETROS WHERE cod_parametro = 'RECARGO_NOCT_DOM';
    v_vh := CASE v_tipo WHEN 'PLANTA' THEN v_sal / 240 ELSE v_sal END;
    FOR r IN (SELECT tipo_hora, cantidad_horas FROM HORAS_TRABAJADAS
              WHERE id_empleado = p_id_empleado AND id_quincena = p_id_quincena) LOOP
        IF    r.tipo_hora = 'NOCTURNA'     THEN v_total := v_total + r.cantidad_horas * v_vh * (v_rn  / 100);
        ELSIF r.tipo_hora = 'DOMINICAL'    THEN v_total := v_total + r.cantidad_horas * v_vh * (v_rd  / 100);
        ELSIF r.tipo_hora = 'NOCTURNA_DOM' THEN v_total := v_total + r.cantidad_horas * v_vh * (v_rnd / 100);
        END IF;
    END LOOP;
    RETURN NVL(v_total, 0);
END fn_recargos;
/

-- 2.3 fn_bonificacion (llama a fn_salario_base_q)
CREATE OR REPLACE FUNCTION fn_bonificacion(p_id_empleado NUMBER) RETURN NUMBER IS
    v_tipo      EMPLEADOS.tipo_contrato%TYPE;
    v_ingreso   EMPLEADOS.fecha_ingreso%TYPE;
    v_antiguedad NUMBER;
    v_sanciones  NUMBER;
    v_base_q     NUMBER;
    v_pct        NUMBER := 0;
BEGIN
    SELECT tipo_contrato, fecha_ingreso INTO v_tipo, v_ingreso FROM EMPLEADOS WHERE id_empleado = p_id_empleado;
    IF v_tipo = 'SERVICIOS' THEN RETURN 0; END IF;
    SELECT COUNT(*) INTO v_sanciones FROM SANCIONES
    WHERE  id_empleado = p_id_empleado AND fecha_sancion >= ADD_MONTHS(SYSDATE, -6);
    IF v_sanciones > 2 THEN RETURN 0; END IF;
    v_antiguedad := TRUNC(MONTHS_BETWEEN(SYSDATE, v_ingreso) / 12);
    v_pct := CASE
        WHEN v_antiguedad BETWEEN 3 AND 5  THEN 0.03
        WHEN v_antiguedad BETWEEN 6 AND 10 THEN 0.06
        WHEN v_antiguedad > 10             THEN 0.10
        ELSE 0
    END;
    v_base_q := fn_salario_base_q(p_id_empleado, '2026-Q1-ENE');
    RETURN v_base_q * v_pct;
END fn_bonificacion;
/

-- 2.4 fn_bruto
CREATE OR REPLACE FUNCTION fn_bruto(p_id_empleado NUMBER, p_id_quincena VARCHAR2)
RETURN NUMBER IS
BEGIN
    RETURN fn_salario_base_q(p_id_empleado, p_id_quincena)
         + fn_recargos(p_id_empleado, p_id_quincena)
         + fn_bonificacion(p_id_empleado);
END fn_bruto;
/

SELECT fn_bruto(1001, '2026-Q1-ENE') FROM DUAL;

-- ============================================================
-- PUNTO 3 — Procedimiento sp_liquidar_empleado con excepciones
-- ============================================================
SAVEPOINT sv_antes_del_procedure;

CREATE OR REPLACE PROCEDURE sp_liquidar_empleado(
    p_id_empleado NUMBER,
    p_id_quincena VARCHAR2
) IS
    v_estado        EMPLEADOS.estado%TYPE;
    v_liq_count     NUMBER(5);
    v_salario_base_q  NUMBER(12,2) := 0;
    v_recargos        NUMBER(12,2) := 0;
    v_bonificacion    NUMBER(12,2) := 0;
    v_bruto           NUMBER(12,2) := 0;
    v_neto            NUMBER(12,2) := 0;
    v_total_deducciones NUMBER(12,2) := 0;
BEGIN
    BEGIN
        SELECT estado INTO v_estado FROM EMPLEADOS WHERE id_empleado = p_id_empleado;
    EXCEPTION
        WHEN NO_DATA_FOUND THEN RAISE_APPLICATION_ERROR(-20001, 'Empleado no encontrado: ' || p_id_empleado);
    END;
    IF v_estado != 'ACTIVO' THEN
        RAISE_APPLICATION_ERROR(-20002, 'Empleado no activo: estado = ' || v_estado);
    END IF;
    SELECT COUNT(*) INTO v_liq_count FROM LIQUIDACION
    WHERE  id_empleado = p_id_empleado AND id_quincena = p_id_quincena;
    IF v_liq_count > 0 THEN
        RAISE_APPLICATION_ERROR(-20003, 'Liquidación ya existe para empleado ' || p_id_empleado || ' quincena ' || p_id_quincena);
    END IF;

    v_salario_base_q := fn_salario_base_q(p_id_empleado, p_id_quincena);
    v_recargos       := fn_recargos(p_id_empleado, p_id_quincena);
    v_bonificacion   := fn_bonificacion(p_id_empleado);
    v_bruto          := v_salario_base_q + v_recargos + v_bonificacion;
    v_neto           := v_bruto - v_total_deducciones;

    INSERT INTO LIQUIDACION (id_liquidacion, id_empleado, id_quincena,
        salario_base_q, recargos, bonificacion, bruto, total_deducciones, neto)
    VALUES (SEQ_LIQUIDACION.NEXTVAL, p_id_empleado, p_id_quincena,
        v_salario_base_q, v_recargos, v_bonificacion, v_bruto, v_total_deducciones, v_neto);
    COMMIT;
EXCEPTION
    WHEN OTHERS THEN ROLLBACK; RAISE;
END sp_liquidar_empleado;
/

-- ============================================================
-- PUNTO 4 — Package PKG_NOMINA (Spec + Body)
-- ============================================================
CREATE OR REPLACE PACKAGE PKG_NOMINA AS
    gc_smlmv NUMBER;
    PROCEDURE sp_liquidar_quincena(p_id_empleado NUMBER, p_id_quincena VARCHAR2);
    PROCEDURE sp_liquidar_quincena(p_id_quincena VARCHAR2);
    FUNCTION fn_total_nomina_sede(p_cod_sede VARCHAR2, p_id_quincena VARCHAR2) RETURN NUMBER;
    FUNCTION fn_reporte_nomina(p_cod_sede VARCHAR2 DEFAULT NULL, p_tipo_contrato VARCHAR2 DEFAULT NULL) RETURN t_lista_liq PIPELINED;
END PKG_NOMINA;
/

-- Body del package (funciones privadas, sobrecarga, pipelined, BULK COLLECT/FORALL)
-- Ver script completo en el archivo descargable.

-- ============================================================
-- PUNTO 5 — Compound Trigger sobre LIQUIDACION
-- ============================================================
CREATE OR REPLACE TRIGGER trg_liquidacion_compound
FOR INSERT ON LIQUIDACION
COMPOUND TRIGGER
    v_neto_negativo BOOLEAN := FALSE;

    BEFORE EACH ROW IS
    BEGIN
        IF :NEW.salario_base_q < 0 THEN
            RAISE_APPLICATION_ERROR(-20010, 'Salario base no puede ser negativo');
        END IF;
        IF :NEW.neto < 0 THEN
            v_neto_negativo := TRUE;
            :NEW.total_deducciones := :NEW.total_deducciones - :NEW.embargo;
            :NEW.embargo := 0;
            :NEW.neto    := :NEW.bruto - :NEW.total_deducciones;
            IF :NEW.neto < 0 THEN
                :NEW.total_deducciones := :NEW.total_deducciones - :NEW.libranzas;
                :NEW.libranzas := 0;
                :NEW.neto      := :NEW.bruto - :NEW.total_deducciones;
            END IF;
        END IF;
    END BEFORE EACH ROW;

    AFTER EACH ROW IS
    BEGIN
        IF v_neto_negativo THEN
            INSERT INTO LOG_NOMINA (id_log, fecha_hora, operacion, usuario, detalle)
            VALUES (SEQ_LOG.NEXTVAL, SYSTIMESTAMP, 'ALERTA_NETO_NEGATIVO', USER,
                'Empleado ' || :NEW.id_empleado || ' — neto negativo ajustado. Neto final: ' || :NEW.neto);
            v_neto_negativo := FALSE;
        END IF;
        IF :NEW.libranzas > 0 THEN
            UPDATE LIBRANZAS SET saldo_pendiente = saldo_pendiente - :NEW.libranzas
            WHERE  id_empleado = :NEW.id_empleado AND estado = 'ACTIVA' AND ROWNUM = 1;
            UPDATE LIBRANZAS SET estado = 'PAGADA'
            WHERE  id_empleado = :NEW.id_empleado AND estado = 'ACTIVA' AND saldo_pendiente <= 0;
        END IF;
    END AFTER EACH ROW;

    AFTER STATEMENT IS
    BEGIN
        INSERT INTO LOG_NOMINA (id_log, fecha_hora, operacion, usuario, detalle)
        VALUES (SEQ_LOG.NEXTVAL, SYSTIMESTAMP, 'INSERT_LIQUIDACION', USER,
            'Lote procesado a las ' || TO_CHAR(SYSTIMESTAMP, 'HH24:MI:SS.FF3'));
    END AFTER STATEMENT;
END trg_liquidacion_compound;
/`,
	},
];
---

<Layout title={`PL/SQL Scripts | David Caicedo`}>
	<Header />

	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<article class="max-w-3xl mx-auto pt-24 sm:pt-32 md:pt-48 pb-16 sm:pb-24 fade-in">

			<a href="/projects"
				class="text-sm font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors mb-8 inline-block"
				data-en={translations.back.en} data-es={translations.back.es}>
				{translations.back.en}
			</a>

			<header class="mb-12">
				<p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-3 tracking-wider uppercase"
					data-en={translations.subtitle.en} data-es={translations.subtitle.es}>
					{translations.subtitle.en}
				</p>
				<h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4"
					data-en={translations.title.en} data-es={translations.title.es}>
					{translations.title.en}
				</h1>
				<p class="text-lg text-gray-600 dark:text-gray-400"
					data-en={translations.description.en} data-es={translations.description.es}>
					{translations.description.en}
				</p>
			</header>

			{scripts.length === 0 ? (
				<div class="flex flex-col items-center justify-center py-24 text-center border border-dashed border-gray-300 dark:border-gray-700 rounded-2xl">
					<span class="text-4xl mb-4">📦</span>
					<p class="text-gray-500 dark:text-gray-400 text-sm"
						data-en={translations.empty.en} data-es={translations.empty.es}>
						{translations.empty.en}
					</p>
				</div>
			) : (
				<div class="space-y-4">
					{scripts.map((script, i) => (
						<div class="border border-gray-200 dark:border-gray-800 rounded-xl overflow-hidden bg-gray-50 dark:bg-gray-900/50 script-card">
							<div class="flex items-center justify-between p-4 sm:p-5 cursor-pointer select-none script-toggle" data-index={i}>
								<div class="flex-1 min-w-0">
									<h3 class="text-sm sm:text-base font-semibold text-gray-900 dark:text-white locale-es">{script.title}</h3>
									<h3 class="text-sm sm:text-base font-semibold text-gray-900 dark:text-white locale-en">{script.titleEN}</h3>
									<p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 locale-es">{script.description}</p>
									<p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 locale-en">{script.descriptionEN}</p>
								</div>
								<div class="flex items-center gap-2 ml-3 shrink-0">
									<a href={script.file} download
										class="px-3 py-1.5 text-xs font-medium rounded-full bg-gray-900 dark:bg-white text-white dark:text-gray-900 hover:animated-bg transition-all"
										data-en={translations.download.en} data-es={translations.download.es}
										onclick="event.stopPropagation()">
										{translations.download.en}
									</a>
									<button
										class="px-3 py-1.5 text-xs font-medium rounded-full border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors view-btn"
										data-en-open={translations.viewCode.en} data-es-open={translations.viewCode.es}
										data-en-close={translations.hideCode.en} data-es-close={translations.hideCode.es}>
										{translations.viewCode.en}
									</button>
									<svg class="w-4 h-4 text-gray-400 transition-transform duration-300 chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
									</svg>
								</div>
							</div>
							<div class="code-panel hidden">
								<div class="border-t border-gray-200 dark:border-gray-800">
									<pre class="overflow-x-auto p-4 sm:p-5 text-xs sm:text-sm leading-relaxed text-gray-800 dark:text-gray-200 font-mono bg-gray-950/5 dark:bg-gray-950/50"><code>{script.code}</code></pre>
								</div>
							</div>
						</div>
					))}
				</div>
			)}

		</article>
	</main>

	<Footer />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			document.querySelector('.fade-in')?.classList.add('visible');
			document.querySelectorAll('.script-toggle').forEach((toggle) => {
				toggle.addEventListener('click', () => {
					const card = toggle.closest('.script-card');
					if (!card) return;
					const panel = card.querySelector('.code-panel');
					const chevron = card.querySelector('.chevron');
					const btn = card.querySelector('.view-btn');
					if (!panel || !chevron || !btn) return;
					const isOpen = !panel.classList.contains('hidden');
					const lang = document.documentElement.getAttribute('data-lang') || 'es';
					if (isOpen) {
						panel.classList.add('hidden');
						chevron.classList.remove('rotate-180');
						btn.textContent = lang === 'es' ? btn.getAttribute('data-es-open')! : btn.getAttribute('data-en-open')!;
					} else {
						panel.classList.remove('hidden');
						chevron.classList.add('rotate-180');
						btn.textContent = lang === 'es' ? btn.getAttribute('data-es-close')! : btn.getAttribute('data-en-close')!;
					}
				});
			});
		});
	</script>
